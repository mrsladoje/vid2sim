{
  "name": "vid2sim-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VID2SIM browser-native Three.js + Rapier WASM viewer (Stream 04 — Presentation)",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "three": "^0.165.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/three": "^0.165.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
