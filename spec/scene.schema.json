{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vid2sim.local/spec/scene.schema.json",
  "title": "SceneSpec v1.0",
  "description": "VID2SIM frozen scene contract (ADR-001). Source of truth for all downstream exporters. DO NOT modify after G0.",
  "type": "object",
  "required": ["version", "world", "ground", "objects", "camera_pose"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "world": {
      "type": "object",
      "required": ["gravity", "up_axis", "unit"],
      "additionalProperties": false,
      "properties": {
        "gravity": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "up_axis": { "type": "string", "enum": ["y", "z"] },
        "unit":    { "type": "string", "enum": ["meters"] }
      }
    },
    "ground": {
      "type": "object",
      "required": ["type", "normal", "material"],
      "additionalProperties": false,
      "properties": {
        "type":   { "type": "string", "enum": ["plane"] },
        "normal": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "material": {
          "type": "object",
          "required": ["friction", "restitution"],
          "additionalProperties": false,
          "properties": {
            "friction":    { "type": "number", "minimum": 0 },
            "restitution": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "objects": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/SceneObject" }
    },
    "camera_pose": { "$ref": "#/$defs/Transform" }
  },
  "$defs": {
    "Transform": {
      "type": "object",
      "required": ["translation", "rotation_quat"],
      "additionalProperties": false,
      "properties": {
        "translation":   { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "rotation_quat": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
        "scale":         { "type": "number", "exclusiveMinimum": 0, "default": 1.0 }
      }
    },
    "SceneObject": {
      "type": "object",
      "required": ["id", "class", "mesh", "transform", "collider", "physics", "material_class", "source"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string", "minLength": 1 },
        "class": { "type": "string", "minLength": 1 },
        "mesh":  { "type": "string" },
        "transform": { "$ref": "#/$defs/Transform" },
        "collider": {
          "type": "object",
          "required": ["shape"],
          "additionalProperties": false,
          "properties": {
            "shape":                { "type": "string", "enum": ["mesh", "sphere", "box", "capsule"] },
            "convex_decomposition": { "type": "boolean", "default": false },
            "hull_paths":           { "type": "array", "items": { "type": "string" } },
            "radius":               { "type": "number", "exclusiveMinimum": 0 },
            "half_extents":         { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
          }
        },
        "physics": {
          "type": "object",
          "required": ["mass_kg", "friction", "restitution", "is_rigid"],
          "additionalProperties": false,
          "properties": {
            "mass_kg":     { "type": "number", "exclusiveMinimum": 0 },
            "friction":    { "type": "number", "minimum": 0 },
            "restitution": { "type": "number", "minimum": 0, "maximum": 1 },
            "is_rigid":    { "type": "boolean" }
          }
        },
        "material_class": { "type": "string" },
        "source": {
          "type": "object",
          "required": ["mesh_origin", "physics_origin"],
          "additionalProperties": false,
          "properties": {
            "mesh_origin":    { "type": "string", "enum": ["hunyuan3d_2.1", "triposg_1.5b", "sf3d", "identity"] },
            "physics_origin": { "type": "string", "enum": ["vlm", "lookup", "manual"] },
            "vlm_reasoning":  { "type": "string", "default": "" }
          }
        }
      }
    }
  }
}
